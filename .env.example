# ===========================================
# DOCKER COMPOSE ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# Domain
DOMAIN=alikhlaskarawang.my.id

# Frontend URL (for CORS)
FRONTEND_URL=https://alikhlaskarawang.my.id

# Backend URL
BACKEND_URL=https://alikhlaskarawang.my.id/api

# JWT Secret - Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_B64

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_USER=sekolah
DB_PASSWORD=your_secure_password_here
DB_NAME=sekolah_modern

# MySQL Root Password (for container initialization)
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
